# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/coldtech?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES=7d

# ── CORS ─────────────────────────────────────────────────
CLIENT_URL=https://coldtechtechnologies.in

# ── Admin bootstrap ──────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Optional ─────────────────────────────────────────────
AUTO_BOOTSTRAP=true

# ── Email (Resend) ────────────────────────────────────────
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From address must be verified in Resend dashboard
# For testing use: onboarding@resend.dev
RESEND_FROM=Coldtech Technologies <rushikeshnabde37@gmail.com>

# ── AI Blog Generator ─────────────────────────────────────
# Google AI Studio (free) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloudinary (image uploads) ────────────────────────────
# Sign up at https://cloudinary.com — free tier is sufficient
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
